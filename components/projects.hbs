<main id="main-content">
    <section class="projects-list" aria-label="Lista de proyectos destacados">
        <div class="container">
            {{#each proyectos}}
            <article class="proyecto" aria-label="Proyecto: {{titulo}}">
                <div class="proyecto__info">
                    <h2 class="proyecto__titulo">
                        {{titulo}}
                        <span class="proyecto__ano">({{ano}})</span>
                    </h2>
                    <p class="proyecto__descripcion">{{descripcion}}</p>
                </div>

                <div class="carousel" data-project-carousel>
                    <div class="carousel__track" role="list" aria-label="Imágenes de {{titulo}}">
                        {{#each imagenes}}
                        <figure class="carousel__slide" role="listitem">
                            <img
                                src="../assets/img/{{src}}"
                                alt="{{alt}}"
                                loading="lazy"
                            >
                        </figure>
                        {{/each}}
                    </div>

                    <button class="carousel__btn carousel__btn--prev" type="button" aria-label="Imagen anterior de {{../titulo}}">
                        &#10216;
                    </button>
                    <button class="carousel__btn carousel__btn--next" type="button" aria-label="Siguiente imagen de {{../titulo}}">
                        &#10217;
                    </button>

                    <div class="carousel__dots" aria-hidden="true">
                        {{#each imagenes}}
                        <span class="carousel__dot{{#if @first}} carousel__dot--active{{/if}}"></span>
                        {{/each}}
                    </div>
                </div>
            </article>
            {{/each}}
        </div>
    </section>
</main>
