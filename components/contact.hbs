<div class="contact-layout">
    <div class="info-box">
        <h2>{{contactInfoTitle}}</h2>
        {{#each contactInfoItems}}
            <p><strong>{{label}}</strong> {{value}}</p>
        {{/each}}
    </div>

    <div class="form-box">
        <h2>{{contactFormTitle}}</h2>

        <form class="contact-form" @submit.prevent="submitContact" novalidate>
            <label class="contact-label">
                {{contactFormLabels.fullName}}
                <input class="contact-input" type="text" v-model="form.name" placeholder="{{contactFormPlaceholders.fullName}}" required>
                <span class="input-error" v-if="errors.name">{{ errors.name }}</span>
            </label>

            <label class="contact-label">
                {{contactFormLabels.email}}
                <input class="contact-input" type="email" v-model="form.email" placeholder="{{contactFormPlaceholders.email}}" required>
                <span class="input-error" v-if="errors.email">{{ errors.email }}</span>
            </label>

            <label class="contact-label">
                {{contactFormLabels.phone}}
                <input class="contact-input" type="tel" v-model="form.phone" placeholder="{{contactFormPlaceholders.phone}}" required>
                <span class="input-error" v-if="errors.phone">{{ errors.phone }}</span>
            </label>

            <label class="contact-label">
                {{contactFormLabels.reason}}
                <select class="contact-select" v-model="form.reason" required>
                    <option value="">{{contactReasonDefaultLabel}}</option>
                    {{#each contactReasonOptions}}
                        <option value="{{value}}">{{label}}</option>
                    {{/each}}
                </select>
                <span class="input-error" v-if="errors.reason">{{ errors.reason }}</span>
            </label>

            <label class="contact-label">
                {{contactFormLabels.message}}
                <textarea class="contact-textarea" rows="5" v-model="form.message" placeholder="{{contactFormPlaceholders.message}}" required></textarea>
                <span class="input-error" v-if="errors.message">{{ errors.message }}</span>
            </label>

            <button class="contact-button" type="submit">{{contactSubmitLabel}}</button>
            <p class="status-message" v-if="status">{{ status }}</p>
        </form>
    </div>

</div>

<div class="contact-location-box info-box">
    <h2>{{contactLocationTitle}}</h2>
    <iframe class="contact-map"
        src="{{contactMapSrc}}">
    </iframe>
</div>