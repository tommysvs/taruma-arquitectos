<section class="quot-section alt">
    <div class="container">
      <div class="form-page">
        <h1>{{quotationForm.title}}</h1>
        <p class="lead">{{quotationForm.lead}}</p>

        <form class="cotizacion-form" @submit.prevent="submitQuotation" novalidate>
          <div class="row">
            <label for="tipo">{{quotationForm.labels.projectType}}</label>
            <select id="tipo" v-model="form.projectType" required>
              <option value="">{{quotationForm.projectTypeDefaultLabel}}</option>
              {{#each quotationForm.projectTypeOptions}}
                <option value="{{value}}">{{label}}</option>
              {{/each}}
            </select>
            <span class="input-error" v-if="errors.projectType">{{ errors.projectType }}</span>
          </div>

          <div class="row two-col">
            <div>
              <label for="superficie">{{quotationForm.labels.area}}</label>
              <input type="number" id="superficie" v-model.number="form.area" placeholder="{{quotationForm.placeholders.area}}" min="1" required>
              <span class="input-error" v-if="errors.area">{{ errors.area }}</span>
            </div>
            <div>
              <label for="presupuesto">{{quotationForm.labels.budget}}</label>
              <input type="text" id="presupuesto" v-model="form.budget" placeholder="{{quotationForm.placeholders.budget}}" required>
              <span class="input-error" v-if="errors.budget">{{ errors.budget }}</span>
            </div>
          </div>

          <div class="row">
            <label for="email">{{quotationForm.labels.email}}</label>
            <input type="email" id="email" v-model="form.email" placeholder="{{quotationForm.placeholders.email}}" required>
            <span class="input-error" v-if="errors.email">{{ errors.email }}</span>
            <small class="field-note">{{quotationForm.notes.email}}</small>
          </div>

          <div class="row">
            <label for="phone">{{quotationForm.labels.phone}}</label>
            <input type="tel" id="phone" v-model="form.phone" placeholder="{{quotationForm.placeholders.phone}}" required>
            <span class="input-error" v-if="errors.phone">{{ errors.phone }}</span>
          </div>

          <div class="row">
            <label for="plazos">{{quotationForm.labels.deadline}}</label>
            <input type="text" id="plazos" v-model="form.deadline" placeholder="{{quotationForm.placeholders.deadline}}" required>
            <span class="input-error" v-if="errors.deadline">{{ errors.deadline }}</span>
          </div>

          <div class="row full-width">
            <label for="description">{{quotationForm.labels.description}}</label>
            <textarea id="description" v-model="form.description" rows="5" placeholder="{{quotationForm.placeholders.description}}" required></textarea>
            <span class="input-error" v-if="errors.description">{{ errors.description }}</span>
          </div>

          <div class="row file-field">
            <label for="imagenes">{{quotationForm.labels.files}}</label>
            <input type="file" id="imagenes" multiple accept="image/*" @change="handleFiles">
            <small class="field-note">{{quotationForm.notes.files}}</small>
          </div>

          <div class="row actions">
            <button type="submit" class="submit-btn">{{quotationForm.submitLabel}}</button>
            <a href="index.html" class="btn-outline">{{quotationForm.backToHomeLabel}}</a>
          </div>

          <p class="status-message" v-if="status">{{ status }}</p>
        </form>
      </div>
    </div>
  </section>

  <section class="quot-section">
    <div class="container">
      {{#each quotationInfoSections}}
        <h3>{{title}}</h3>

        {{#if paragraphs}}
          {{#each paragraphs}}
            <p>{{this}}</p>
          {{/each}}
        {{/if}}

        {{#if list}}
          <ul>
            {{#each list}}
              <li>{{this}}</li>
            {{/each}}
          </ul>
        {{/if}}
      {{/each}}
    </div>
  </section>