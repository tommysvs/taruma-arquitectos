<div class="container-blog">
    {{#each blogArticles}}
        <div class="article">
            <span class="category">{{category}}</span>
            <h2>{{title}}</h2>
            <p><strong>{{authorLabel}}</strong> {{author}} | <strong>{{dateLabel}}</strong> {{date}}</p>
            <p>{{body}}</p>

            <div class="comments-section">
                <h3>{{commentsTitle}}</h3>
                <div id="comments{{id}}"></div>
                <input type="text" id="commentInput{{id}}" placeholder="{{commentsPlaceholder}}">
                <button onclick="addComment({{id}})">{{commentsButton}}</button>
            </div>
        </div>
    {{/each}}
</div>