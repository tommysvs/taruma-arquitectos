<main id="main-content">
    <section class="gallery-section" aria-label="Galería de fotos por categoría">
        <div class="container">
            {{#each categorias}}
            <div class="gallery-categoria" id="{{id}}">
                <h2 class="gallery-categoria__titulo">{{nombre}}</h2>
                <div class="gallery-grid" role="list">
                    {{#each imagenes}}
                    <figure
                        class="img-card"
                        role="listitem"
                        tabindex="0"
                        data-src="../assets/img/{{src}}"
                        data-alt="{{alt}}"
                        aria-label="Ver imagen ampliada: {{alt}}"
                    >
                        <img
                            src="../assets/img/{{src}}"
                            alt="{{alt}}"
                            loading="lazy"
                        >
                    </figure>
                    {{/each}}
                </div>
            </div>
            {{/each}}
        </div>
    </section>
</main>

<!-- Modal lightbox -->
<div id="gallery-modal" class="gallery-modal" role="dialog" aria-modal="true" aria-label="Vista ampliada de imagen" hidden>
    <button id="modal-close" class="gallery-modal__close" type="button" aria-label="Cerrar imagen">&times;</button>
    <button id="modal-prev" class="gallery-modal__nav gallery-modal__nav--prev" type="button" aria-label="Imagen anterior">&#10216;</button>
    <figure class="gallery-modal__content">
        <img id="modal-img" src="" alt="">
        <figcaption id="modal-caption" class="gallery-modal__caption"></figcaption>
    </figure>
    <button id="modal-next" class="gallery-modal__nav gallery-modal__nav--next" type="button" aria-label="Imagen siguiente">&#10217;</button>
</div>
