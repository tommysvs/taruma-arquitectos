<section class="section">
    <h3>{{processTitle}}</h3>

    <div class="process-grid">
        {{#each processCards}}
            <div class="process-card">
                <h4>{{title}}</h4>
                <p>{{description}}</p>
            </div>
        {{/each}}

    </div>

    <div class="process-diagram">
        {{#each processSteps}}
            <div class="step">
                <span class="circle">{{number}}</span>
                <p>{{label}}</p>
            </div>

            {{#unless @last}}
                <div class="line"></div>
            {{/unless}}
        {{/each}}

    </div>

    <ul class="times-list">
        {{#each timeList}}
            <li>{{stage}}: {{duration}}</li>
        {{/each}}
    </ul>
</section>