<section class="home-hero">
    <div class="home-hero-content container">
        <h2>{{homeHeroTitle}}</h2>
    </div>
</section>

<section id="proyectos" class="home-section alt">
    <div class="container">
        <h3>{{featuredProjects.title}}</h3>
        <div class="custom-carousel" data-carousel data-autoplay="3400">
            <div class="carousel-viewport">
                <div class="carousel-track">
                    {{#each featuredProjects.slides}}
                        <div class="carousel-slide"><img src="{{src}}" alt="{{alt}}" /></div>
                    {{/each}}
                </div>
            </div>
            <div class="carousel-dots" aria-label="{{featuredProjects.carouselAriaLabel}}"></div>
        </div>
    </div>
</section>

<section id="nosotros" class="home-section">
    <div class="container">
        <h3>{{homeAbout.title}}</h3>
        <div class="about-content">
            {{#each homeAbout.cards}}
                <div class="about-card">
                    <h4>{{title}}</h4>
                    <p>{{text}}</p>
                </div>
            {{/each}}
        </div>
    </div>
</section>

<section id="servicios" class="home-section alt">
    <div class="container">
        <h3>{{homeServices.title}}</h3>
        <div class="service-links">
            {{#each homeServices.links}}
                <a href="{{href}}">{{label}}</a>
            {{/each}}
        </div>
    </div>
</section>

<section id="noticias" class="home-section">
    <div class="container">
        <h3>{{homeNews.title}}</h3>
        <ul class="news-list">
            {{#each homeNews.items}}
                <li><strong>{{date}}</strong> {{text}}</li>
            {{/each}}
        </ul>
    </div>
</section>